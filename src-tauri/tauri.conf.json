{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MornAudioProcessor",
  "version": "0.1.1",
  "identifier": "com.morn.audio-processor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "MornAudioProcessor",
        "width": 900,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 700,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
